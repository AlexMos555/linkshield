# ═════════════════════════════════════════════════════════════════
# .dockerignore — keep secrets, dev tools, and junk OUT of the image.
# If you add new secret files, add them here FIRST before committing.
# ═════════════════════════════════════════════════════════════════

# ── Secrets (CRITICAL — keep all .env out of the image) ─────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.aws/
.gcp/
*.keytab

# ── Git / VCS ────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes
.gitmodules
.github/

# ── Dev tooling ──────────────────────────────────────────────────
.claude/
.cursor/
.ecc/
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Python dev ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
coverage.xml

# ── Node / JS dev (not needed for Python API image) ─────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Non-API source trees — API image doesn't need them ──────────
landing/
mobile/
extension/
extension-firefox/
extension-safari/
ml/

# ── Large dev-only data ─────────────────────────────────────────
data/top-1m.csv
data/phishtank.csv
data/feature_log.jsonl
catboost_info/
*.zip

# ── Docs & planning ─────────────────────────────────────────────
.planning/
ROADMAP.html
*.md
!README.md

# ── Tests (no need in prod image) ───────────────────────────────
tests/
benchmark/
pytest.ini

# ── Docker / CI files (don't copy into image) ───────────────────
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# ── Misc ────────────────────────────────────────────────────────
*.log
*.pid
Procfile
Makefile
start.sh
linkshield-extension.zip
linkshield-firefox.zip

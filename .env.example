# ═══════════════════════════════════════════════════
# LinkShield — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════

# App
DEBUG=false

# ── Supabase ──
# Get from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-min-32-characters-long

# ── Redis ──
# Local: redis://localhost:6379
# Upstash: rediss://default:PASSWORD@HOST:PORT
REDIS_URL=redis://:linkshield_dev@localhost:6379

# ── Google Safe Browsing ──
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_SAFE_BROWSING_KEY=

# ── PhishTank (optional) ──
PHISHTANK_API_KEY=

# ── IPQualityScore (optional, 5K/month free) ──
IPQUALITYSCORE_KEY=

# ── CORS ──
ALLOWED_ORIGINS=https://linkshield.io,chrome-extension://YOUR_EXTENSION_ID

# ── Rate Limits ──
FREE_TIER_DAILY_LIMIT=10
PAID_TIER_DAILY_LIMIT=10000
BURST_LIMIT=10
BURST_WINDOW_SECONDS=10

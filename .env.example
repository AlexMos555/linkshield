# ═══════════════════════════════════════════════════
# Cleanway — Environment Configuration
# Copy to .env and fill in your values. Do NOT commit .env
# ═══════════════════════════════════════════════════

# App
DEBUG=false

# ── Supabase ──
# Get from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-min-32-characters-long
# Management API token (for scripts, migrations, project admin)
SUPABASE_ACCESS_TOKEN=sbp_...

# ── Redis ──
# Local: redis://localhost:6379
# Upstash: rediss://default:PASSWORD@HOST:PORT
# Railway addon: rediss://default:PASSWORD@HOST.railway.app:PORT
REDIS_URL=redis://:cleanway_dev@localhost:6379

# ── Google Safe Browsing ──
# Get from: https://console.cloud.google.com/apis/credentials
# Either env var name is accepted (api/config.py uses AliasChoices).
# _API_KEY is the preferred / industry-standard form going forward.
GOOGLE_SAFE_BROWSING_API_KEY=

# ── PhishTank (optional) ──
PHISHTANK_API_KEY=

# ── IPQualityScore (optional, 5K/month free) ──
IPQUALITYSCORE_KEY=

# ── CORS ──
# Список доменов через запятую. Для extensions — chrome-extension://EXTENSION_ID
ALLOWED_ORIGINS=https://cleanway.ai,https://www.cleanway.ai,chrome-extension://YOUR_EXTENSION_ID

# ── Rate Limits ──
FREE_TIER_DAILY_LIMIT=10
PAID_TIER_DAILY_LIMIT=10000
BURST_LIMIT=10
BURST_WINDOW_SECONDS=10
# When Redis is unreachable:
#   false (default, dev/staging) → log + allow request (fail-open)
#   true  (set in PROD)         → return 503 (fail-closed)
# Without `true` in prod, an attacker who notices Redis is down can bypass
# our quotas and burn paid 3rd-party API budgets (Google Safe Browsing,
# IPQualityScore, etc.) until Redis recovers.
RATE_LIMIT_FAIL_CLOSED=false

# Benchmark bypass token (optional). When set, a request carrying a matching
# X-Cleanway-Benchmark header skips the public-endpoint IP rate limit. Used
# ONLY by the weekly fresh-URL benchmark CI job so it can measure a large
# sample without throttling. Leave empty in normal deployments. To enable
# weekly auto-refresh of docs/benchmarks/latest.json, set the SAME random
# value here (Railway env) and in the GitHub Actions repo secret
# BENCHMARK_BYPASS_TOKEN. Rotate by changing both.
BENCHMARK_BYPASS_TOKEN=

# ── Stripe (Phase B) ──
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Sentry (optional) ──
SENTRY_DSN=

# ═══════════════════════════════════════════════════
# Client env vars (for landing / mobile / extensions)
# ═══════════════════════════════════════════════════

# ── Landing (Next.js) — prefix with NEXT_PUBLIC_ for client-side ──
# Используется в landing/app/**/*.tsx
NEXT_PUBLIC_API_URL=https://api.cleanway.ai
NEXT_PUBLIC_STRIPE_PUB_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Mobile (Expo) — prefix with EXPO_PUBLIC_ для client-side ──
# Используется в mobile/src/services/api.ts
EXPO_PUBLIC_API_URL=https://api.cleanway.ai
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Browser Extensions (Chrome/Firefox/Safari) ──
# Extensions не используют process.env — вместо этого:
# Default: https://api.cleanway.ai (hardcoded в background/index.js и utils/api.js)
# Dev override: Options page → "API URL" поле → http://localhost:8000 → Save
# Это пишется в chrome.storage.local.api_url и перекрывает default в runtime.

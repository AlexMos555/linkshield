{
  "name": "@cleanway/email-templates",
  "version": "0.1.0",
  "private": true,
  "description": "Transactional email templates for Cleanway. React Email source → HTML + plaintext output, localized via @cleanway/i18n-strings. Provider-agnostic: backend picks Resend/SES at runtime.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./templates/*": "./src/templates/*.tsx"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "out/**/*.html",
    "out/**/*.txt"
  ],
  "scripts": {
    "build": "node ../../scripts/build-emails.mjs",
    "preview": "email dev --dir src/templates"
  },
  "dependencies": {
    "@react-email/components": "^0.0.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@react-email/render": "^1.0.0",
    "@types/react": "^19.0.0",
    "react-email": "^3.0.0",
    "typescript": "^5.6.3"
  }
}

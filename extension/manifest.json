{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extension_name__",
  "description": "__MSG_extension_description__",
  "version": "0.1.0",

  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "contextMenus",
    "notifications"
  ],

  "host_permissions": [
    "https://api.cleanway.ai/*",
    "https://*.cleanway.ai/*",
    "http://localhost:8000/*",
    "https://mail.google.com/*",
    "https://outlook.office.com/*",
    "https://outlook.live.com/*",
    "https://mail.yahoo.com/*"
  ],

  "background": {
    "service_worker": "src/background/index.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/utils/local-scorer.js",
        "src/content/tracking-cleaner.js",
        "src/content/crypto-blocker.js",
        "src/content/weekly-report.js",
        "src/content/security-score.js",
        "src/content/breach-check.js",
        "src/content/index.js"
      ],
      "css": ["styles/badges.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://mail.yahoo.com/*"
      ],
      "js": ["src/content/webmail.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "32": "public/icons/icon32.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },

  "options_page": "src/options/options.html",

  "icons": {
    "16": "public/icons/icon16.png",
    "32": "public/icons/icon32.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+L", "mac": "Command+Shift+L" },
      "description": "Open Cleanway popup"
    },
    "check-page": {
      "suggested_key": { "default": "Ctrl+Shift+K", "mac": "Command+Shift+K" },
      "description": "Check current page safety"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["public/icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}

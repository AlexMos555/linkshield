{
  "manifest_version": 2,
  "name": "LinkShield — Phishing Protection",
  "description": "Automatic phishing link detection with privacy audit. Your browsing data lives only on your device.",
  "version": "0.1.0",

  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "contextMenus",
    "https://api.linkshield.io/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "scripts": ["src/background/index.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/content/weekly-report.js",
        "src/content/security-score.js",
        "src/content/index.js"
      ],
      "css": ["styles/badges.css"],
      "run_at": "document_idle"
    }
  ],

  "browser_action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "32": "public/icons/icon32.png",
      "48": "public/icons/icon48.png"
    }
  },

  "options_ui": {
    "page": "src/options/options.html",
    "browser_style": false
  },

  "icons": {
    "16": "public/icons/icon16.png",
    "32": "public/icons/icon32.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "linkshield@linkshield.io",
      "strict_min_version": "109.0"
    }
  }
}

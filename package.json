{
  "name": "cleanway-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Cleanway root \u2014 npm workspaces for shared packages across landing, mobile, extensions.",
  "workspaces": [
    "packages/api-types",
    "packages/api-client",
    "packages/email-templates",
    "landing",
    "mobile"
  ],
  "scripts": {
    "build:i18n": "python3 scripts/build-i18n.py",
    "build:extensions": "bash scripts/build-extensions.sh",
    "build:api-types": "bash scripts/generate-api-types.sh",
    "build:all": "npm run build:api-types && npm run build:i18n && npm run build:extensions && npm run build:emails",
    "test:api": "pytest tests/ -q",
    "build:landing": "npm -w landing run build",
    "build:emails": "tsx scripts/build-emails.mjs"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "next": "15.1.11"
  }
}
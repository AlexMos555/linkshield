{
  "name": "cleanway-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Cleanway root — npm workspaces for shared packages across landing, mobile, extensions.",
  "workspaces": [
    "packages/api-types",
    "packages/api-client",
    "packages/email-templates",
    "landing",
    "mobile"
  ],
  "scripts": {
    "build:i18n": "python3 scripts/build-i18n.py",
    "build:extensions": "bash scripts/build-extensions.sh",
    "build:api-types": "bash scripts/generate-api-types.sh",
    "build:addin": "node scripts/sync-addin.cjs",
    "build:all": "npm run build:api-types && npm run build:i18n && npm run build:extensions && npm run build:emails && npm run build:addin",
    "test:api": "pytest tests/ -q",
    "test:api-client": "NODE_NO_WARNINGS=1 node --experimental-strip-types scripts/test-api-client-errors.mjs",
    "build:landing": "npm -w landing run build",
    "build:emails": "tsx scripts/build-emails.mjs"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "next": "15.1.11"
  },
  "dependencies": {
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "optionalDependencies": {
    "@parcel/watcher-linux-x64-glibc": "^2.5.6"
  }
}
